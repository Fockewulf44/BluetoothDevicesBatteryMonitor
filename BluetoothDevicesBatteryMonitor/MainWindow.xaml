<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="BluetoothDevicesBatteryMonitor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BluetoothDevicesBatteryMonitor"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="BluetoothDevicesBatteryMonitor">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ListBox Name="DevicesListBox" Grid.Column="0" Margin="10"/>
        <Button Name="btnRefresh" Grid.Column="1" Click="OnBtnRefreshClick" VerticalAlignment="Top" Content="GetBluetoothDevices" Margin="10"/>

    </Grid>



</Window>
